{
  "name": "frame",
  "description": "Full-canvas border frame. Rendered as a ring via custom _render. Color and thickness are tweakable.",
  "tweakable": {
    "fill": "Frame color (default: #9f452d)",
    "_frameThickness": "Border thickness in px (default: 6)",
    "_frameRadius": "Corner radius (default: 12)",
    "_framePadT/_framePadR/_framePadB/_framePadL": "Edge padding (default: 20 each)"
  },
  "fabricObject": {
    "type": "rect",
    "version": "5.3.0",
    "originX": "left",
    "originY": "top",
    "fill": "#9f452d",
    "stroke": "#2B2318",
    "strokeWidth": 0,
    "strokeDashArray": null,
    "strokeLineCap": "butt",
    "strokeDashOffset": 0,
    "strokeLineJoin": "miter",
    "strokeUniform": false,
    "strokeMiterLimit": 4,
    "angle": 0,
    "flipX": false,
    "flipY": false,
    "opacity": 1,
    "shadow": null,
    "visible": true,
    "backgroundColor": "",
    "fillRule": "nonzero",
    "paintFirst": "fill",
    "globalCompositeOperation": "source-over",
    "skewX": 0,
    "skewY": 0,
    "rx": 0,
    "ry": 0,
    "_customName": "Frame",
    "lockMovementX": false,
    "lockMovementY": false,
    "lockScalingX": false,
    "lockScalingY": false,
    "lockRotation": false,
    "_isFrame": true,
    "_frameOffset": 20,
    "_framePadT": 0,
    "_framePadR": 0,
    "_framePadB": 0,
    "_framePadL": 0,
    "_shadowSpread": 0,
    "_frameThickness": 13.5,
    "_innerShadow": {
      "lx": 23,
      "rx": 23,
      "uy": 23,
      "dy": 23,
      "blur": 9,
      "color": "rgba(0,0,0,0.6)",
      "_linked": true
    }
  }
}