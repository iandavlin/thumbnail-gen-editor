node_modules/

# ── Output thumbnails ────────────────────────────────────────────────────────
# All generated JSON and rendered images are local only.
# The empty folder structure is preserved via .gitkeep.
output/*
!output/16x9/
!output/1x1/
output/16x9/*
!output/16x9/.gitkeep
output/1x1/*
!output/1x1/.gitkeep
*.preview.jpg
*.pptx
*.png
*.jpg
*.jpeg

# ── Episode / per-shoot assets ───────────────────────────────────────────────
# Dated episode folders and named shoot folders are local only.
# _permanent/ is tracked for manifests; its images are not.
assets/20*/
assets/episode/
assets/stewmac_sale/
assets/Creston_*/
assets/*.jpg
assets/*.jpeg
assets/*.png

assets/_permanent/logos/*
!assets/_permanent/logos/.gitkeep
assets/_permanent/misc/*
!assets/_permanent/misc/.gitkeep

# ── OS / editor cruft ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
.env
.env.*

# ── Build artifacts ───────────────────────────────────────────────────────────
dist/
skills/

# ── Claude Code session data ─────────────────────────────────────────────────
.claude/

# ── Tooling backups ───────────────────────────────────────────────────────────
*.bak
*.bak.*
